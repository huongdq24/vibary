/**
 * Core Philosophy: This ruleset implements a hybrid security model designed for a pastry shop application.
 * It strictly separates public, read-only data from private, user-owned data. Publicly accessible
 * information like cakes, categories, and news articles can be read by anyone but cannot be modified by clients.
 * All customer-specific data, such as profiles and orders, is protected under a strict ownership model,
 * ensuring users can only access their own information. User-generated content, like reviews, is
 * publicly readable but write access is restricted to the original author.
 *
 * Data Structure: The data is organized into two main types:
 * 1. Top-level public collections: /cakes, /categories, /news_articles, /quiz_questions. These are
 *    globally readable.
 * 2. User-owned data trees: All private data is nested under /customers/{customerId}, where the document
 *    ID matches the user's authentication UID. This includes subcollections like /orders and /order_items.
 *
 * Key Security Decisions:
 * - Read-Only Public Data: All top-level collections intended for public browsing are configured to be
 *   read-only for clients. Writes to these collections are disallowed, anticipating that they will be
 *   managed by a backend service or an administrative role not defined here.
 * - Strict Path-Based Ownership: Security for customer data (/customers/{customerId}) and all its
 *   subcollections is enforced using the customerId from the document path. This is a highly performant
 *   and secure pattern that prevents users from accessing or manipulating each other's data.
 * - Denormalization for Authorization: Reviews contain a denormalized `customerId` field. This allows
 *   rules on the /reviews collection to grant update/delete permissions directly to the author without
 *   requiring slow or complex lookups to other documents.
 * - Structural Segregation: Private data (like orders) is structurally separated into a user-specific
 *   subcollection, which is more secure and performant for list queries than storing them in a single
 *   top-level collection with ownership flags.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for update and delete
     * operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --------------------------------
    // Public Collections
    // --------------------------------

    /**
     * @description Publicly readable cake information. Writes are disabled for clients.
     * @path /cakes/{cakeId}
     * @allow (get) Any user, signed in or not, can read a specific cake's details.
     * @deny (create) A signed-in user cannot create a new cake document.
     * @principle Public read access for catalog data, with writes reserved for backend/admin processes.
     */
    match /cakes/{cakeId} {
      allow get, list: if true;
      allow create: if false; // TODO: Implement admin-only access for creating cakes.
      allow update: if false; // TODO: Implement admin-only access for updating cakes.
      allow delete: if false; // TODO: Implement admin-only access for deleting cakes.
    }

    /**
     * @description Publicly readable cake categories. Writes are disabled for clients.
     * @path /categories/{categoryId}
     * @allow (list) Any user, signed in or not, can list all cake categories.
     * @deny (update) A signed-in user cannot modify an existing category document.
     * @principle Public read access for catalog data, with writes reserved for backend/admin processes.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if false; // TODO: Implement admin-only access for creating categories.
      allow update: if false; // TODO: Implement admin-only access for updating categories.
      allow delete: if false; // TODO: Implement admin-only access for deleting categories.
    }

    /**
     * @description Publicly readable news articles. Writes are disabled for clients.
     * @path /news_articles/{newsArticleId}
     * @allow (get) Any user, signed in or not, can read a news article.
     * @deny (delete) A signed-in user cannot delete a news article.
     * @principle Public read access for content, with writes reserved for backend/admin processes.
     */
    match /news_articles/{newsArticleId} {
      allow get, list: if true;
      allow create: if false; // TODO: Implement admin-only access for creating articles.
      allow update: if false; // TODO: Implement admin-only access for updating articles.
      allow delete: if false; // TODO: Implement admin-only access for deleting articles.
    }

    /**
     * @description Publicly readable quiz questions. Writes are disabled for clients.
     * @path /quiz_questions/{quizQuestionId}
     * @allow (list) Any user, signed in or not, can list all quiz questions.
     * @deny (create) A signed-in user cannot create a new quiz question.
     * @principle Public read access for interactive content, with writes reserved for backend/admin processes.
     */
    match /quiz_questions/{quizQuestionId} {
      allow get, list: if true;
      allow create: if false; // TODO: Implement admin-only access for creating questions.
      allow update: if false; // TODO: Implement admin-only access for updating questions.
      allow delete: if false; // TODO: Implement admin-only access for deleting questions.
    }

    // --------------------------------
    // User-Generated Content
    // --------------------------------

    /**
     * @description Customer reviews for a specific cake. Reviews are publicly readable.
     * @path /cakes/{cakeId}/reviews/{reviewId}
     * @allow (create) A signed-in user (auth.uid: 'user_abc') can create a review with `customerId: 'user_abc'`.
     * @deny (update) A user (auth.uid: 'user_xyz') cannot update a review where `resource.data.customerId` is 'user_abc'.
     * @principle Enforces document ownership for writes while allowing public reads. Validates relational integrity.
     */
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid && request.resource.data.cakeId == cakeId;
      allow update: if isExistingOwner(resource.data.customerId) && request.resource.data.customerId == resource.data.customerId && request.resource.data.cakeId == resource.data.cakeId;
      allow delete: if isExistingOwner(resource.data.customerId);
    }

    // --------------------------------
    // User-Owned Data
    // --------------------------------

    /**
     * @description Customer profile data. A user can only access their own document.
     * @path /customers/{customerId}
     * @allow (create) A new user (auth.uid: 'user_abc') can create their own profile at /customers/user_abc.
     * @deny (get) A user (auth.uid: 'user_xyz') cannot get the document at /customers/user_abc.
     * @principle Restricts access to a user's own data tree using path-based ownership.
     */
    match /customers/{customerId} {
      allow get: if isOwner(customerId);
      allow list: if isOwner(customerId); // Allows a user to check for their own document
      allow create: if isOwner(customerId) && request.resource.data.id == customerId;
      allow update: if isExistingOwner(customerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(customerId);

      /**
       * @description A customer's orders. Access is inherited from the parent customer document.
       * @path /customers/{customerId}/orders/{orderId}
       * @allow (list) A user (auth.uid: 'user_abc') can list all orders under /customers/user_abc/orders.
       * @deny (get) A user (auth.uid: 'user_xyz') cannot get an order from /customers/user_abc/orders/{orderId}.
       * @principle Path-based ownership ensures users can only access their own orders.
       */
      match /orders/{orderId} {
        allow get: if isOwner(customerId);
        allow list: if isOwner(customerId);
        allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
        allow update: if isExistingOwner(customerId) && request.resource.data.customerId == resource.data.customerId;
        allow delete: if isExistingOwner(customerId);

        /**
         * @description Items within a specific order. Access is inherited from the customer path.
         * @path /customers/{customerId}/orders/{orderId}/order_items/{orderItemId}
         * @allow (create) A user (auth.uid: 'user_abc') can create an item in their own order.
         * @deny (list) A user (auth.uid: 'user_xyz') cannot list items in another user's order.
         * @principle Ensures deep path security and relational integrity with the parent order.
         */
        match /order_items/{orderItemId} {
          allow get: if isOwner(customerId);
          allow list: if isOwner(customerId);
          allow create: if isOwner(customerId) && request.resource.data.orderId == orderId && get(/databases/$(database)/documents/customers/$(customerId)/orders/$(orderId)).data.customerId == customerId;
          allow update: if isExistingOwner(customerId) && request.resource.data.orderId == resource.data.orderId;
          allow delete: if isExistingOwner(customerId);
        }
      }
    }
  }
}