
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Using UID is a robust workaround if Custom Claims are not set up.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }

    // ================================
    // PUBLIC-READABLE COLLECTIONS
    // ================================

    match /{collection in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ================================
    // USER-SPECIFIC DATA
    // ================================
    
    match /customers/{customerId} {
      // Admins can get any customer, owners can only get their own.
      allow get: if isOwner(customerId) || isAdmin();
      // Only admins can list all customers.
      allow list: if isAdmin();
      allow create: if isOwner(customerId);
      // Owners and admins can update.
      allow update: if isOwner(customerId) || isAdmin();
      // Only admins can delete.
      allow delete: if isAdmin();

      // Rule for the `orders` subcollection
      // This single rule handles all access to orders.
      // Firestore evaluates this rule for collection group queries.
      match /orders/{orderId} {
        // Admin gets full access (read/write).
        // Owner gets access to their own orders (read/write).
        allow read, write: if isAdmin() || isOwner(customerId);

        // Rule for `order_items` sub-subcollection
        match /order_items/{orderItemId} {
          allow read, write: if isAdmin() || isOwner(customerId);
        }
      }
    }
    
    // ================================
    // OTHER NESTED COLLECTIONS
    // ================================
    
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if (resource.data.customerId == request.auth.uid) || isAdmin();
    }
  }
}
