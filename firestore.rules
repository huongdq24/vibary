
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // CRITICAL: COLLECTION GROUP RULES FIRST
    // ============================================
    
    match /{path=**}/orders/{orderId} {
      allow list, get, create, update, delete: if isAdmin();
    }
    
    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
    }
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // For development, any signed-in user is considered an admin.
      // For production, you should replace this with a more secure check,
      // such as checking for a custom claim: request.auth.token.admin == true
      return isSignedIn();
    }
    
    // ============================================
    // PUBLIC COLLECTIONS
    // ============================================
    
    match /cakes/{cakeId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid && request.resource.data.cakeId == cakeId;
        allow update: if isSignedIn() && resource.data.customerId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.customerId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }
    
    match /product_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /news_articles/{newsArticleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /quiz_questions/{quizQuestionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ingredients/{ingredientId} {
      allow get, list, write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /analytics/{analyticsId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ============================================
    // USER-OWNED DATA
    // ============================================
    
    match /customers/{customerId} {
      allow create: if isOwner(customerId);
      allow read: if isOwner(customerId) || isAdmin();
      allow update: if isOwner(customerId) || isAdmin();
      allow delete: if isAdmin();
      
      match /orders/{orderId} {
        allow read: if isOwner(customerId) || isAdmin();
        allow write: if isOwner(customerId) || isAdmin();
        
        match /order_items/{orderItemId} {
          allow read: if isOwner(customerId) || isAdmin();
          allow write: if isOwner(customerId) || isAdmin();
        }
      }
      
      match /addresses/{addressId} {
        allow read: if isOwner(customerId) || isAdmin();
        allow write: if isOwner(customerId) || isAdmin();
      }
      
      match /favorites/{favoriteId} {
        allow read: if isOwner(customerId) || isAdmin();
        allow write: if isOwner(customerId) || isAdmin();
      }
    }
  }
}
