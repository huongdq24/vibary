
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Using UID is a robust workaround if Custom Claims are not set up.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }

    // ================================
    // COLLECTION GROUP RULES
    // ================================
    
    // This rule allows an admin to perform a collection group query on 'orders'.
    // This is required for the admin dashboard to list all orders.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
      // Note: 'get', 'create', 'update', 'delete' are NOT granted here.
      // Those are handled by the more specific rule under /customers/{customerId}.
    }

    // ================================
    // PUBLIC-READABLE COLLECTIONS
    // ================================

    match /{collection in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ================================
    // USER-SPECIFIC DATA
    // ================================
    
    match /customers/{customerId} {
      // Admins can get any customer, owners can only get their own.
      allow get: if isOwner(customerId) || isAdmin();
      // Only admins can list all customers.
      allow list: if isAdmin();
      allow create: if isOwner(customerId);
      // Owners and admins can update.
      allow update: if isOwner(customerId) || isAdmin();
      // Only admins can delete.
      allow delete: if isAdmin();

      // Rules for a user accessing their OWN orders, or an admin accessing a SPECIFIC order.
      match /orders/{orderId} {
        // 'list' is handled by the collection group rule above for admins.
        allow get: if isOwner(customerId) || isAdmin();
        allow write: if isOwner(customerId) || isAdmin();

        // Rule for `order_items` sub-subcollection
        match /order_items/{orderItemId} {
          allow read, write: if isOwner(customerId) || isAdmin();
        }
      }
    }
    
    // ================================
    // OTHER NESTED COLLECTIONS
    // ================================
    
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if (resource.data.customerId == request.auth.uid) || isAdmin();
    }
  }
}
