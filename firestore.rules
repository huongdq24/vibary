
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // This UID 'WEM5X92ExuRA6I82nZjRVeCru6i2' corresponds to manager@vibary.com
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }
    
    // ================================
    // PUBLIC & ADMIN-WRITE COLLECTIONS
    // ================================

    match /{collection in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ================================
    // USER-OWNED DATA (Specific Paths)
    // ================================
    
    match /customers/{customerId} {
      // Rules for the customer document itself
      allow create: if isOwner(customerId);
      allow get, update: if isOwner(customerId);
      allow get, update, list, delete: if isAdmin();

      // --- ORDERS Subcollection ---
      // These rules apply to direct document access and collection group queries.
      match /orders/{orderId} {
        // Admin has full read/write access, which includes 'list' for collection group queries.
        allow read, write: if isAdmin();
        
        // Owner can get/write their own order. 'read' is covered by the admin rule.
        // We use separate 'get' to not interfere with admin's 'list'.
        allow get, write: if isOwner(customerId);

        // --- ORDER ITEMS Sub-subcollection ---
        match /order_items/{orderItemId} {
           allow read, write: if isOwner(customerId);
           allow read, write: if isAdmin();
        }
      }
    }
    
    // ================================
    // PUBLIC-READ, USER-WRITE COLLECTIONS
    // ================================
    
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      
      // Separate allow statements to prevent OR evaluation errors.
      allow update, delete: if resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
