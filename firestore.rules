
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // An admin is a user with a 'role' field set to 'admin' in their customer document.
      // This allows for more flexible role management directly in the database.
      return request.auth != null &&
             get(/databases/$(database)/documents/customers/$(request.auth.uid)).data.role == 'admin';
    }

    // --- COLLECTION GROUP RULE ---
    // This rule is CRITICAL for admin queries. It allows admins to list documents
    // across all 'orders' subcollections. 'read' includes 'get' and 'list'.
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    // --- PUBLIC & ADMIN-WRITABLE COLLECTIONS ---
    match /(cakes|categories|news_articles|quiz_questions)/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // --- REVIEWS ---
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update, delete: if isOwner(resource.data.customerId);
    }
    
    // --- CUSTOMER DATA & ORDERS ---
    match /customers/{customerId} {
      // Customers can create their own profile. Admins can view/update any profile.
      allow create: if isOwner(customerId);
      allow get, update: if isOwner(customerId) || isAdmin();
      // Only admins can list all customers.
      allow list: if isAdmin();

      // Nested rule for orders within a customer's document.
      // This allows an owner to access their own order, and an admin to write to it.
      // Admin reads are handled by the collection group rule above.
      match /orders/{orderId} {
        allow get, write: if isOwner(customerId) || isAdmin();

        // Nested rule for items within an order.
        match /order_items/{orderItemId} {
          allow read, write: if isOwner(customerId) || isAdmin();
        }
      }
    }
  }
}
