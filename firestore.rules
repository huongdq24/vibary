
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // This UID 'Uljim6Xf6UeAlfEM0VV1lY4vaKm1' corresponds to admin@vibary.com
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'Uljim6Xf6UeAlfEM0VV1lY4vaKm1';
    }
    
    // ================================
    // PUBLIC & ADMIN-WRITE COLLECTIONS
    // ================================

    match /{collection in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ===========================================
    // COLLECTION GROUP QUERIES (Admin-specific)
    // ===========================================
    
    // This rule allows the admin to perform LIST queries across all 'orders' collections.
    // It is critical for the admin dashboard/orders page.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }

    // ================================
    // USER-OWNED DATA (Specific Paths)
    // ================================
    
    match /customers/{customerId} {
      // Rules for the customer document itself
      allow create: if isOwner(customerId);
      allow get, update: if isOwner(customerId);
      // Admin has elevated permissions on customer profiles
      allow get, update, list, delete: if isAdmin();

      // --- ORDERS Subcollection (Single Document Access) ---
      match /orders/{orderId} {
        // Admin can GET, UPDATE, or DELETE any single order document.
        // 'list' is handled by the collection group rule above.
        allow get, write: if isAdmin();
        
        // Owner can GET or CREATE/UPDATE their own order.
        allow get, write: if isOwner(customerId);

        // --- ORDER ITEMS Sub-subcollection ---
        match /order_items/{orderItemId} {
           // Admin has full access to order items.
           allow read, write: if isAdmin();
           // Owner has full access to their own order items.
           allow read, write: if isOwner(customerId);
        }
      }
    }
    
    // ================================
    // PUBLIC-READ, USER-WRITE COLLECTIONS
    // ================================
    
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      
      // Owner can update/delete their own review
      allow update, delete: if resource.data.customerId == request.auth.uid;
      // Admin can update/delete any review
      allow update, delete: if isAdmin();
    }
  }
}
