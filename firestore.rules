
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a production app, this would ideally be a custom claim set on the user's token.
      // For this project, we define the admin by a specific email address for simplicity.
      return request.auth != null && request.auth.token.email == 'manager@vibary.com';
    }

    // --- PUBLIC & ADMIN-WRITABLE COLLECTIONS ---
    match /(cakes|categories|news_articles|quiz_questions)/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // --- REVIEWS ---
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update, delete: if isOwner(resource.data.customerId);
    }
    
    // --- CUSTOMER DATA ---
    match /customers/{customerId} {
      allow create: if isOwner(customerId);
      allow get, update: if isOwner(customerId) || isAdmin();
      allow list: if isAdmin();

      // Path-specific rule for a customer's own orders.
      // This rule is for direct access, NOT for collection group queries.
      match /orders/{orderId} {
        allow get, write: if isOwner(customerId) || isAdmin();

        match /order_items/{orderItemId} {
          allow read, write: if isOwner(customerId) || isAdmin();
        }
      }
    }

    // --- COLLECTION GROUP RULE for 'orders' ---
    // This rule is ONLY for collection group queries on 'orders'.
    // It grants read access to admins across all 'orders' subcollections.
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
  }
}
