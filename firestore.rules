
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // This is a temporary workaround. For better security, use custom claims.
      // See: https://firebase.google.com/docs/auth/admin/custom-claims
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }

    // ================================
    // ADMIN "GOD MODE"
    // ================================
    // This rule allows users identified as admins to read and write any document
    // in the database. This is a simple but powerful way to manage admin access.
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // ===============================================
    // PUBLIC & USER-SPECIFIC RULES (for non-admins)
    // ===============================================
    // The following rules apply to users who are NOT admins.
    // The admin rule above will grant access before these are evaluated for admins.

    // Publicly readable collections
    match /{collectionName in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow get: if true;
      allow list: if true;
      // Write access is handled by the admin rule.
    }

    // Customer documents
    match /customers/{customerId} {
      // A user can get their own document. This is also needed for the isAdminByRole check.
      allow get: if isOwner(customerId);
      // A user can create their own customer document.
      allow create: if isOwner(customerId);
      // A user can update their own document.
      allow update: if isOwner(customerId);

      // A user can read and write to their own orders and subcollections.
      match /orders/{orderId}/{document=**} {
        allow read, write: if isOwner(customerId);
      }
    }

    // Cake reviews
    match /cakes/{cakeId}/reviews/{reviewId} {
      // Anyone can read reviews.
      allow read: if true;
      // Only authenticated users can create reviews for themselves.
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      // Only the review's owner can update or delete it.
      allow update, delete: if isSignedIn() && resource.data.customerId == request.auth.uid;
    }
  }
}
