
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a production app, this would ideally be a custom claim set on the user's token.
      // For this project, we define the admin by a specific email address for simplicity.
      return isSignedIn() && request.auth.token.email == 'manager@vibary.com';
    }

    // --------------------------------
    // Public & Admin Writable Collections
    // --------------------------------

    // Cakes, Categories, News, Ingredients, and Quiz questions can be read by anyone.
    // Only administrators can create, update, or delete them.
    match /(cakes|categories|news_articles|quiz_questions|ingredients)/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------------------
    // User-Generated Content
    // --------------------------------

    // Reviews can be read by anyone.
    // Users can create reviews and can only modify or delete their own reviews.
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if resource.data.customerId == request.auth.uid;
    }

    // --------------------------------
    // User & Customer Data
    // --------------------------------

    // Rules for the 'customers' collection
    match /customers/{customerId} {
      // Admins can get any specific customer document and list all customers.
      allow get, list: if isAdmin();
      // A user can create, read, and update their OWN customer document. They cannot delete it.
      allow create, get, update: if isOwner(customerId);
    }
    
    // Rules for the 'orders' subcollection within a customer document
    match /customers/{customerId}/orders/{orderId} {
        // An owner can read/write their own orders. An admin can read/write any order.
        // This combined rule is necessary for admin collection group queries to work.
        allow read, write: if isOwner(customerId) || isAdmin();

        // Rules for the nested 'order_items' subcollection
        match /order_items/{orderItemId} {
            // Permissions are inherited. Admins and owners can read/write order items.
            allow read, write: if isOwner(customerId) || isAdmin();
        }
    }
  }
}
