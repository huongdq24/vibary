
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a production app, this would ideally be a custom claim set on the user's token.
      // For this project, we define the admin by a specific email address for simplicity.
      return isSignedIn() && request.auth.token.email == 'manager@vibary.com';
    }

    // Public collections are readable by anyone, writable by admins.
    match /(cakes|categories|news_articles|quiz_questions)/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ingredients are admin-only
    match /ingredients/{ingredientId} {
        allow read, write: if isAdmin();
    }

    // Reviews are readable by anyone, but only the owner can create/edit/delete.
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update, delete: if isOwner(resource.data.customerId);
    }

    // Customer-specific data
    match /customers/{customerId} {
      // Users can create their own profile.
      allow create: if isOwner(customerId);
      // Admins can get any customer profile. Users can only get/update their own.
      // Admins can also list all customers.
      allow read, update: if isOwner(customerId) || isAdmin();
      // Only admins can list all customers.
      allow list: if isAdmin();

      // Nested Orders: for single document access
      match /orders/{orderId} {
        // Admins can read any order. Owners can read their own.
        // Admins can list all orders (via collection group query).
        allow read: if isOwner(customerId) || isAdmin();
        // Admins or owners can write to an order.
        allow write: if isOwner(customerId) || isAdmin();

        // Nested Order Items
        match /order_items/{orderItemId} {
          allow read, write: if isOwner(customerId) || isAdmin();
        }
      }
    }
  }
}
