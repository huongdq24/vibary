
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a production app, this would ideally be a custom claim set on the user's token.
      // For this project, we define the admin by a specific email address for simplicity.
      return request.auth != null && request.auth.token.email == 'manager@vibary.com';
    }

    // --- PUBLIC & ADMIN-WRITABLE COLLECTIONS ---
    match /(cakes|categories|news_articles|quiz_questions)/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // --- REVIEWS ---
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.customerId);
      allow update, delete: if isOwner(resource.data.customerId);
    }
    
    // --- CUSTOMER DATA & ORDERS ---
    match /customers/{customerId} {
      // Customers can create their own profile. Admins can view/update any profile.
      allow create: if isOwner(customerId);
      allow get, update: if isOwner(customerId) || isAdmin();
      // Only admins can list all customers.
      allow list: if isAdmin();

      // Nested rule for orders within a customer's document.
      match /orders/{orderId} {
        // Admins can read/write any order. Owners can read/write their own orders.
        // 'read' includes 'get' and 'list', which is required for the admin's collection group query.
        allow read, write: if isOwner(customerId) || isAdmin();

        // Nested rule for items within an order.
        match /order_items/{orderItemId} {
          allow read, write: if isOwner(customerId) || isAdmin();
        }
      }
    }
  }
}
