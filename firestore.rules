rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        request.auth.uid in [
          'WEM5X92ExuRA6I82nZjRVeCru6i2',
          'Uljim6Xf6UeAlfEM0VV1lY4vaKm1'
        ]
      );
    }

    // Collection Group Query cho orders - QUAN TRỌNG
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }

    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
    }

    match /cakes/{cakeId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() 
          && request.resource.data.customerId == request.auth.uid 
          && request.resource.data.cakeId == cakeId;
        allow update: if isExistingOwner(resource.data.customerId);
        allow delete: if isExistingOwner(resource.data.customerId) || isAdmin();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news_articles/{newsArticleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quiz_questions/{quizQuestionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow create: if isOwner(customerId);
      allow update: if isExistingOwner(customerId) || isAdmin();
      allow delete: if isAdmin();

      match /orders/{orderId} {
        allow read, write: if isOwner(customerId) || isAdmin();

        match /order_items/{orderItemId} {
          allow read: if isOwner(customerId) || isAdmin();
          allow create: if isOwner(customerId) && request.resource.data.orderId == orderId;
          allow update: if isExistingOwner(customerId) || isAdmin();
          allow delete: if isExistingOwner(customerId) || isAdmin();
        }
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(customerId) || isAdmin();
      }

      match /favorites/{favoriteId} {
        allow read, write: if isOwner(customerId);
      }
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /analytics/{analyticsId} {
      allow read, write: if isAdmin();
    }
  }
}