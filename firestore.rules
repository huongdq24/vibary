
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{path=**}/orders/{orderId} {
      allow list, get, create, update, delete: if request.auth != null;
    }
    
    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth != null;
    }
    
    match /cakes/{cakeId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.customerId == request.auth.uid;
        allow delete: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      }
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /news_articles/{newsArticleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /quiz_questions/{quizQuestionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ingredients/{ingredientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /analytics/{analyticsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /birthday_cake_sizes/{sizeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /customers/{customerId} {
      allow create: if isOwner(customerId);
      allow read: if isOwner(customerId) || isAdmin();
      allow update: if isOwner(customerId) || isAdmin();
      allow delete: if isAdmin();
      
      match /orders/{orderId} {
        allow read: if isOwner(customerId) || isAdmin();
        allow write: if isOwner(customerId) || isAdmin();
        
        match /order_items/{orderItemId} {
          allow read: if isOwner(customerId) || isAdmin();
          allow write: if isOwner(customerId) || isAdmin();
        }
      }
      
      match /addresses/{addressId} {
        allow read: if isOwner(customerId) || isAdmin();
        allow write: if isOwner(customerId) || isAdmin();
      }
      
      match /favorites/{favoriteId} {
        allow read: if isOwner(customerId) || isAdmin();
        allow write: if isOwner(customerId) || isAdmin();
      }
    }
  }
}
