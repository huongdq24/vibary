
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Using UID is a robust workaround if Custom Claims are not set up.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }

    // ================================
    // PUBLIC COLLECTIONS
    // ================================

    match /{collection in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      // Anyone can read public data.
      allow read: if true;
      // Only admins can modify public data.
      allow write: if isAdmin();
    }
    
    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ================================
    // USER & NESTED DATA
    // ================================
    
    match /customers/{customerId} {
      // User can create their own profile.
      allow create: if isOwner(customerId);
      // User can get their own profile. Admin can get any.
      allow get: if isOwner(customerId) || isAdmin();
      // User can update their own profile. Admin can update any.
      allow update: if isOwner(customerId) || isAdmin();
      // Only admins can list or delete customers.
      allow list, delete: if isAdmin();

      // --- ORDERS Subcollection ---
      match /orders/{orderId} {
        // This structure explicitly separates permissions to avoid conflicts
        // during collection group queries.

        // 1. A user can GET their own order.
        allow get: if isOwner(customerId);
        
        // 2. An admin can READ (get + list) any/all orders.
        // This rule is what allows the collection group query for the admin dashboard.
        allow read: if isAdmin();
        
        // 3. A user can WRITE to their own order, and an admin can WRITE to any.
        allow write: if isOwner(customerId) || isAdmin();

        // --- ORDER ITEMS Sub-subcollection ---
        match /order_items/{orderItemId} {
          // Inherits parent logic: only owner or admin can access.
          allow read, write: if isOwner(customerId) || isAdmin();
        }
      }
    }
    
    // ================================
    // OTHER NESTED COLLECTIONS
    // ================================
    
    match /cakes/{cakeId}/reviews/{reviewId} {
      // Anyone can read reviews.
      allow read: if true;
      // Only signed-in users can create a review for themselves.
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      // Only the review author or an admin can update/delete.
      allow update, delete: if (resource.data.customerId == request.auth.uid) || isAdmin();
    }
  }
}
