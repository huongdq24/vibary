
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Using UID is a robust workaround if Custom Claims are not set up.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }

    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    // Ingredients are fully controlled by admins.
    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }


    // ================================
    // PUBLIC-READABLE COLLECTIONS
    // ================================

    // Cakes, Categories, News, and Quizzes are readable by anyone, but only writable by admins.
    match /{collectionName in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // ================================
    // USER-SPECIFIC & MIXED-ACCESS DATA
    // ================================

    // Customer profiles. Users can manage their own, Admins can manage all.
    match /customers/{customerId} {
      // Admin can list all customers. Users can only get their own.
      allow read: if isAdmin() || isOwner(customerId);
      // Users can create their own profile.
      allow create: if isOwner(customerId);
      // Users can update their own profile, Admins can update any.
      allow update: if isOwner(customerId) || isAdmin();
      // Only admins can delete customer profiles.
      allow delete: if isAdmin();

      // Orders are nested under customers.
      // This rule allows admins to perform collection group queries on 'orders'.
      match /orders/{orderId}/{document=**} {
        allow read, write: if isOwner(customerId) || isAdmin();
      }
    }


    // Cake reviews are nested under cakes.
    match /cakes/{cakeId}/reviews/{reviewId} {
      // Anyone can read reviews.
      allow read: if true;
      // Only authenticated users can create reviews for themselves.
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      // Owners and Admins can update or delete reviews.
      allow update, delete: if (resource.data.customerId == request.auth.uid) || isAdmin();
    }
  }
}
