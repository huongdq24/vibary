
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the user has admin privileges by looking for a 'role' field
     * in their corresponding document in the 'customers' collection.
     */
    function isAdmin() {
      // This get() call requires a rule that allows the user to read their own customer document without recursion.
      return isSignedIn() && get(/databases/$(database)/documents/customers/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * Validates that required fields exist in the request data.
     */
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ================================
    // PUBLIC COLLECTIONS
    // ================================

    /**
     * Cakes, Categories, News, Quizzes
     * @description Publicly readable data. Admin-only writes.
     */
    match /{collectionName in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * Ingredients Collection
     * @description Raw material inventory. Admin-only access.
     */
    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ================================
    // COLLECTION GROUP QUERIES
    // ================================

    /**
     * Orders & OrderItems Collection Group
     * @description Allows admins to query all orders/items across all customers.
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
    
    match /{path=**}/order_items/{orderItemId} {
        allow read: if isAdmin();
    }

    // ================================
    // USER-GENERATED CONTENT
    // ================================

    /**
     * Cake Reviews (Subcollection)
     * @description Customer reviews for specific cakes.
     */
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && hasRequiredFields(['customerId', 'cakeId', 'rating', 'comment'])
        && request.resource.data.customerId == request.auth.uid 
        && request.resource.data.cakeId == cakeId;
      allow update, delete: if isOwner(resource.data.customerId) || isAdmin();
    }

    // ================================
    // USER-OWNED DATA (RESTRUCTURED)
    // ================================

    /**
     * Customers Collection
     * @description Customer profile data and nested orders.
     */
    match /customers/{customerId} {
      // --- CRITICAL FIX FOR isAdmin() RECURSION ---
      // Allow users to GET their own document. This is non-recursive and allows the get() inside isAdmin() to succeed.
      allow get: if isOwner(customerId);
      // Allow admins to LIST all customer documents.
      allow list: if isAdmin();
      
      // Allow CREATE for new users creating their own profile.
      allow create: if isOwner(customerId) 
        && hasRequiredFields(['email', 'firstName', 'lastName']);
      
      // Allow UPDATE for owners (who can't change their email) or admins.
      allow update: if (isOwner(customerId) && request.resource.data.email == resource.data.email) || isAdmin();
      
      // Allow DELETE only for admins.
      allow delete: if isAdmin();

      /**
       * Customer Orders (Subcollection)
       */
      match /orders/{orderId} {
        // An owner can manage their own order. An admin can manage any order.
        allow read, write: if isOwner(customerId) || isAdmin();

        /**
         * Order Items (Subcollection)
         */
        match /order_items/{orderItemId} {
          // Permissions are inherited from the parent order.
          allow read, write: if isOwner(customerId) || isAdmin();
        }
      }

      /**
       * Optional Subcollections
       */
      match /addresses/{addressId} {
        allow read, write: if isOwner(customerId) || isAdmin();
      }

      match /favorites/{favoriteId} {
        allow read, write: if isOwner(customerId) || isAdmin();
      }
    }

    // ================================
    // SYSTEM & OTHER COLLECTIONS
    // ================================
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /analytics/{analyticsId} {
      allow read, write: if isAdmin();
    }
  }
}
