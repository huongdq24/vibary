
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is the designated admin based on their email.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'manager@vibary.com';
    }

    // --------------------------------
    // Public Read / Admin Write Collections
    // --------------------------------

    /**
     * @description Publicly readable collections. Writes are restricted to authenticated users (admins).
     * @paths /cakes/{cakeId}, /categories/{categoryId}, /news_articles/{newsArticleId}, 
     *        /quiz_questions/{quizQuestionId}, /ingredients/{ingredientId}
     */
    match /{collectionName}/{docId} 
    where collectionName in ['cakes', 'categories', 'news_articles', 'quiz_questions', 'ingredients'] {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------------------
    // User-Generated Content
    // --------------------------------

    /**
     * @description Customer reviews for a specific cake. Reviews are publicly readable.
     *              Users can only create, update, or delete their OWN reviews.
     * @path /cakes/{cakeId}/reviews/{reviewId}
     */
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      // Allow create if user is signed in and the review's customerId matches their UID.
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      // Allow update/delete if the user is the owner of the existing review document.
      allow update, delete: if isSignedIn() && resource.data.customerId == request.auth.uid;
    }

    // --------------------------------
    // Admin access for collection group queries
    // --------------------------------
    
    /**
     * @description Allows admin users to perform collection group queries on 'orders'.
     *              This is necessary for the admin dashboard and orders page to function.
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    // --------------------------------
    // User & Customer Data
    // --------------------------------

    /**
     * @description Customer profile data. Admins can read all profiles.
     *              A user can only write to their own profile.
     * @path /customers/{customerId}
     */
    match /customers/{customerId} {
      allow read: if isAdmin();
      allow write: if isOwner(customerId);

      /**
       * @description A customer's orders. Write access is protected by ownership.
       *              Read access for admins is handled by the collection group rule above.
       * @path /customers/{customerId}/orders/{orderId}
       */
      match /orders/{orderId} {
        allow write: if isOwner(customerId);

        /**
         * @description Items within a specific order. Admins can read, owner can write.
         * @path /customers/{customerId}/orders/{orderId}/order_items/{orderItemId}
         */
        match /order_items/{orderItemId} {
          allow read: if isAdmin();
          allow write: if isOwner(customerId);
        }
      }
    }
  }
}
