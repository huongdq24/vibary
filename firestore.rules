
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user has admin privileges via custom claims.
     * To make a user an admin, you must set a custom claim on their account.
     * Example (using Firebase Admin SDK):
     * admin.auth().setCustomUserClaims(uid, { admin: true });
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // --------------------------------
    // Public Read / Admin Write Collections
    // --------------------------------

    /**
     * @description Publicly readable collections. Writes are restricted to authenticated users.
     * @paths /cakes/{cakeId}, /categories/{categoryId}, /news_articles/{newsArticleId}, 
     *        /quiz_questions/{quizQuestionId}, /ingredients/{ingredientId}
     * @allow (read) Any user can read data.
     * @allow (write) Only authenticated users can create, update, or delete data.
     */
    match /{collectionName}/{docId} 
    where collectionName in ['cakes', 'categories', 'news_articles', 'quiz_questions', 'ingredients'] {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --------------------------------
    // User-Generated Content
    // --------------------------------

    /**
     * @description Customer reviews for a specific cake. Reviews are publicly readable.
     *              Users can only create, update, or delete their OWN reviews.
     * @path /cakes/{cakeId}/reviews/{reviewId}
     */
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      // Allow create if user is signed in and the review's customerId matches their UID.
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      // Allow update/delete if the user is the owner of the existing review document.
      allow update, delete: if isSignedIn() && resource.data.customerId == request.auth.uid;
    }

    // --------------------------------
    // Admin access for collection group queries
    // --------------------------------
    
    /**
     * @description Allows admin users (any signed-in user) to perform collection group queries on 'orders'.
     *              This is necessary for the admin dashboard and orders page to function.
     *              The more specific rule under /customers/{customerId} still protects writes.
     * @path /{path=**}/orders/{orderId}
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isSignedIn();
    }

    // --------------------------------
    // User-Owned Private Data
    // --------------------------------

    /**
     * @description Customer profile data. A user can only access their own document.
     * @path /customers/{customerId}
     */
    match /customers/{customerId} {
      // A user can only read, create, update, or delete their OWN customer document.
      allow read, write: if isOwner(customerId);

      /**
       * @description A customer's orders. Access is inherited from the parent customer document.
       * @path /customers/{customerId}/orders/{orderId}
       */
      match /orders/{orderId} {
        // A user can only read and write their OWN orders.
        allow read, write: if isOwner(customerId);

        /**
         * @description Items within a specific order. Access is inherited from the customer path.
         * @path /customers/{customerId}/orders/{orderId}/order_items/{orderItemId}
         */
        match /order_items/{orderItemId} {
          // A user can only read and write their OWN order items.
          allow read, write: if isOwner(customerId);
        }
      }
    }
  }
}
