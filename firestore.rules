
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Using UID is a robust workaround if Custom Claims are not set up.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }

    // ================================
    // PUBLIC-READABLE COLLECTIONS
    // ================================

    match /{collection in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ================================
    // USER-SPECIFIC DATA (TOP-LEVEL)
    // ================================
    
    match /customers/{customerId} {
      allow get: if isOwner(customerId) || isAdmin();
      allow list, delete: if isAdmin();
      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId) || isAdmin();
      // NOTE: Subcollection rules are now handled by collection group matches below.
    }

    // ================================
    // NESTED & USER-GENERATED CONTENT (VIA COLLECTION GROUPS)
    // ================================
    
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if (resource.data.customerId == request.auth.uid) || isAdmin();
    }
    
    // This single rule governs all 'orders' collections, wherever they are nested.
    match /{path=**}/orders/{orderId} {
      // Allow access if the user is an admin OR if they are the owner of the parent customer document.
      allow read, write: if isAdmin() || (path[0] == 'customers' && isOwner(path[1]));
    }
    
    // This rule governs all 'order_items' collections.
    match /{path=**}/order_items/{orderItemId} {
      // Similar logic: check for admin or ownership via the path.
      allow read, write: if isAdmin() || (path[0] == 'customers' && isOwner(path[1]));
    }
  }
}
