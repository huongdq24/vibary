
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================
    // HELPER FUNCTIONS
    // ================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Using UID is a robust workaround if Custom Claims are not set up.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WEM5X92ExuRA6I82nZjRVeCru6i2';
    }

    // ================================
    // PUBLIC-READABLE COLLECTIONS
    // ================================

    // Cakes, Categories, News, and Quizzes are readable by anyone.
    match /{collection in ['cakes', 'categories', 'news_articles', 'quiz_questions']}/{docId} {
      allow read: if true;
      allow write: if isAdmin(); // Only admins can write to public data.
    }
    
    // ================================
    // ADMIN-ONLY COLLECTIONS
    // ================================

    match /ingredients/{ingredientId} {
      allow read, write: if isAdmin();
    }

    // ================================
    // USER-SPECIFIC & MIXED-ACCESS
    // ================================
    
    // Customer profiles:
    // - Users can read/create/update their own profile.
    // - Admins can read/update any profile and list all profiles.
    match /customers/{customerId} {
      allow get: if isOwner(customerId) || isAdmin();
      allow list, delete: if isAdmin();
      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId) || isAdmin();

      // Nested Orders:
      // - This rule handles direct access to a specific order document.
      // - It does NOT cover collection group queries.
      match /orders/{orderId} {
        allow read, write: if isOwner(customerId) || isAdmin();
        
        // Order Items nested under orders
        match /order_items/{orderItemId} {
           allow read, write: if isOwner(customerId) || isAdmin();
        }
      }
    }

    // Cake Reviews:
    // - Anyone can read.
    // - Signed-in users can create their own reviews.
    // - Owners or Admins can update/delete.
    match /cakes/{cakeId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if (resource.data.customerId == request.auth.uid) || isAdmin();
    }
    
    // ================================
    // COLLECTION GROUP RULES
    // ================================
    
    // This is the critical rule that was missing.
    // It allows an admin to perform a 'list' or 'get' query across the entire 'orders' collection group.
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
  }
}
