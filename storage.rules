
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This allows anyone to view images in your app.
    match /{allPaths=**} {
      allow read;
      
      // Allow writes (uploads, updates, deletes) only for authenticated users.
      // This is a much safer rule for production and is required for client-side uploads.
      allow write: if request.auth != null;
    }
  }
}
