rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Public read access for all files is allowed.
      allow read;
      // Allow writes only for authenticated users.
      // This is a more secure rule and helps ensure auth state is respected.
      allow write: if request.auth != null;
    }
  }
}
