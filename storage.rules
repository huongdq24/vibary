
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This allows anyone to view images in your app.
    match /{allPaths=**} {
      allow read;
      
      // Allow writes (uploads, updates, deletes) if true.
      // This is a temporary, insecure rule for debugging purposes to rule out
      // authentication issues with storage uploads.
      // In production, this should be restricted, e.g., 'if request.auth != null;'.
      allow write: if true;
    }
  }
}
