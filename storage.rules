
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This allows anyone to view images in your app.
    match /{allPaths=**} {
      allow read;
      
      // DEBUG: Temporarily allowing writes from anyone to diagnose upload issues.
      // This is insecure for a production environment. Once the issue is resolved,
      // this should be changed back to `allow write: if request.auth != null;`
      allow write: if true;
    }
  }
}
