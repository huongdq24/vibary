
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access for all files.
    // This allows anyone to view images, which is common for a public website.
    match /{allPaths=**} {
      allow read;
    }

    // Secure the 'uploads' folder.
    // Only authenticated users are allowed to upload files into this folder.
    match /uploads/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
