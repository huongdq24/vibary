
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This allows anyone to view images in your app.
    match /{allPaths=**} {
      allow read;
      
      // Allow writes (uploads, updates, deletes) only if the user is authenticated.
      // This is a security measure to prevent unauthorized uploads.
      // TEMPORARY DEBUGGING STEP: Allow all writes to isolate the issue.
      allow write: if true;
    }
  }
}
