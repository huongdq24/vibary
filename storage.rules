rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Allow public read access to all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow public read on product images, but restrict writes to signed-in users.
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
