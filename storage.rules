
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // WARNING: These rules are insecure and are only for development.
    // They allow public read and write access to your entire storage bucket.
    // You should secure your rules before deploying to production.
    match /{allPaths=**} {
      allow read, write;
    }
  }
}
