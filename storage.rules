
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This allows anyone to view images in your app.
    match /{allPaths=**} {
      allow read;
      
      // DEBUG: Temporarily allow writes from anyone to diagnose upload issues.
      allow write: if true;
    }
  }
}
